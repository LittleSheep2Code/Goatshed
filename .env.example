NUXT_PUBLIC_API_BASE_URL=https://api.solian.app

# OAuth provider endpoints (FloatingIsland)
NUXT_PUBLIC_OAUTH_PROVIDER_NAME=FloatingIsland
NUXT_PUBLIC_OAUTH_CLIENT_ID=
NUXT_OAUTH_CLIENT_SECRET=
NUXT_PUBLIC_OAUTH_AUTHORIZE_URL=https://id.solian.app/auth/authorize
NUXT_PUBLIC_OAUTH_TOKEN_URL=https://api.solian.app/padlock/auth/open/token
NUXT_PUBLIC_OAUTH_USER_INFO_URL=https://api.solian.app/padlock/auth/open/userinfo
NUXT_PUBLIC_OAUTH_SCOPE=openid profile email
NUXT_PUBLIC_OAUTH_REDIRECT_URL=

# Session signing secret for this blog app
NUXT_AUTH_SESSION_SECRET=replace-this-with-a-long-random-secret

# Optional OAuth debug logging (1/true)
NUXT_OAUTH_DEBUG=0
OPENAI_API_KEY=your-api-key

# Clone agent model configuration
# Examples:
# CLONE_AGENT_MODEL=deepseek/deepseek-chat
# CLONE_AGENT_MODEL=deepseek/deepseek-reasoner
# CLONE_AGENT_MODEL=custom/doubao-seed-2-0-lite-260215
CLONE_AGENT_MODEL=deepseek/deepseek-chat

# Optional: custom OpenAI-compatible endpoint for the clone model
# Example (ByteDance/Ark): https://ark.cn-beijing.volces.com/api/v3
CLONE_AGENT_MODEL_URL=

# Optional: API key for the custom endpoint above
CLONE_AGENT_MODEL_API_KEY=

# Multimodal model for image/file processing (used when user sends images/files)
# Defaults to google/gemini-2.5-flash if not set
# Examples:
# CLONE_AGENT_MULTIMODAL_MODEL=openai/gpt-4o
# CLONE_AGENT_MULTIMODAL_MODEL=google/gemini-2.5-flash
# CLONE_AGENT_MULTIMODAL_MODEL=anthropic/claude-3-5-sonnet
CLONE_AGENT_MULTIMODAL_MODEL=

# Optional: custom endpoint for the multimodal model (falls back to CLONE_AGENT_MODEL_URL if not set)
CLONE_AGENT_MULTIMODAL_MODEL_URL=

# Optional: API key for the multimodal model endpoint (falls back to CLONE_AGENT_MODEL_API_KEY if not set)
CLONE_AGENT_MULTIMODAL_MODEL_API_KEY=

# Force reasoning mode on/off regardless of model naming.
# Supported true values: 1, true, yes, on
# Supported false values: 0, false, no, off
# Leave empty to auto-detect from CLONE_AGENT_MODEL.
CLONE_AGENT_REASONING=

# Optional max reasoning/tool loop steps per request (default: 3 when reasoning, otherwise 6)
CLONE_AGENT_MAX_STEPS=

# Shared memory scope for clone agent (all users share the same memory thread/resource)
CLONE_AGENT_SHARED_MEMORY_THREAD=clone-global-thread
CLONE_AGENT_SHARED_MEMORY_RESOURCE=clone-global-resource

# Data storage paths (override for Docker volume mapping)
# Defaults to relative paths for local development
MASTRA_DB_PATH=./mastra.db
NITRO_DATA_DIR=.data
